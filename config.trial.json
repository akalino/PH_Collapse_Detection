{
  "run": {
    "run_id": "gcp_trial_v1",
    "output_root": "output/gcp_trial_v1",
    "max_workers": 4,
    "base_seed": 17
  },
  "shared": {
    "n_list": [100],
    "d_list": [50],
    "hom_dims": [0, 1],
    "eps_list": [0.1, 0.5],
    "alpha": 0.1,
    "p": 0.1,
    "n_sim": 5,
    "landmark": false,
    "tau_reference_family": "gaussian"
  },
  "tau_parallel": {
    "enabled": true,
    "out_path": "calibration/tau_map.csv",
    "cache_root": "calibration/tau_cache",
    "families": ["gaussian", "uniform_ball"]
  },
  "null_parallel": {
    "enabled": true,
    "out_path": "simulations/null_simulation.csv",
    "families": ["gaussian", "uniform_ball"]
  },
  "alt_parallel": {
    "enabled": true,
    "out_path": "simulations/alt_simulation.csv",
    "families": ["kplane", "spiked_gaussian"]
  }
}